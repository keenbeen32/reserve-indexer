# Envio API token — create or update at https://envio.dev/app/api-tokens
ENVIO_API_TOKEN="<YOUR-API-TOKEN>"

# RPC URLs per chain (used by the Effect API for ERC20 / Governor / Timelock /
# StakingVault / getTransactionReceipt reads). The ENVIO_ prefix is required by
# the hosted runtime.
ENVIO_RPC_URL_1="<YOUR-ETHEREUM-RPC-ENDPOINT>"
ENVIO_RPC_URL_8453="<YOUR-BASE-RPC-ENDPOINT>"
ENVIO_RPC_URL_56="<YOUR-BSC-RPC-ENDPOINT>"
